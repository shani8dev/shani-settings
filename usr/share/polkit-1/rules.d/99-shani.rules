// ═════════════════════════════════════════════════════════════════════════════
// TIER 2 — wheel group, AUTH_ADMIN
// Irreversible destructive operations — administrator credential required
// ═════════════════════════════════════════════════════════════════════════════

polkit.addRule(function(action, subject) {
    if ((action.id == "org.freedesktop.udisks2.ata-secure-erase" ||
         action.id == "org.freedesktop.udisks2.ata-enhanced-secure-erase") &&
        subject.active == true && subject.local == true &&
        subject.isInGroup("wheel")) {
            return polkit.Result.AUTH_ADMIN;
    }
});
