# -----------------------------------------------------------------------------
# Usage:
#   make          runs the first target (all)
#   make build
#   make run
#   make clean
# NOTE: Indentation must use real TAB characters, not spaces.
# -----------------------------------------------------------------------------

.PHONY: all build run clean

all: build

build:
